# ============================================================
# easy-hive Bot 配置文件（复制为 .env 后填写）
# ============================================================

# ---------- 影巢 Open API（必填）----------
# 在 https://hdhive.com → 个人设置 → API Keys 中创建
HDHIVE_API_KEY=

# ---------- Telegram（必填）----------
# 从 @BotFather 创建 Bot 后获得的 Token
TELEGRAM_BOT_TOKEN=
# 允许使用 Bot 的 chat id，多个用英文逗号分隔
# 个人 ID：给 @userinfobot 发消息即可获取；群组 ID 通常为负数
TELEGRAM_CHAT_ID=

# ---------- TMDB（可选）----------
# 不配置则只能用 /movie <id>、/tv <id> 按 TMDB ID 查询
# 注册 https://www.themoviedb.org → Settings → API → 申请 API Key (v3 auth)
TMDB_API_KEY=

# ---------- 网盘类型过滤（可选）----------
# 只展示指定 pan_type 的资源，逗号分隔，不区分大小写；留空 = 不过滤
# 影巢已知类型：115、123、quark（夸克）、baidu（百度）、ed2k
# 示例：只看 115 资源
# PAN_TYPES=115
# 示例：115 + 夸克
# PAN_TYPES=115,quark

# ---------- Symedia 转存到 115（可选）----------
# 当前仅支持通过 Symedia cloud_helper 插件转存到 115 网盘
# 接口：POST {SYMEDIA_BASE_URL}/api/v1/plugin/cloud_helper/add_share_urls_115?token={SYMEDIA_TOKEN}
# 流程：点「转存到115」→ 先调影巢 unlock 获取真实 115 链接 → 发给 Symedia
#
# Symedia 服务地址（Web 面板同一端口）
# SYMEDIA_BASE_URL=http://192.168.31.223:8095
#
# Symedia API Token（默认 symedia；可在 Symedia 设置 → 系统 → API_TOKEN 中查看或修改）
# SYMEDIA_TOKEN=symedia
#
# 115 目标文件夹 CID（默认 0 = 根目录）
# 获取方式：浏览器打开 115 网盘 → 进入目标文件夹 → 地址栏里 cid=xxx 即为文件夹 ID
# SYMEDIA_PARENT_ID=0
#
# 请求超时（秒），大文件转存可能较慢
# SYMEDIA_TIMEOUT=120

# ---------- 代理（可选）----------
# 本机直接运行一般不需要；Docker 内访问宿主机代理示例：
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# 内网地址不走代理
# NO_PROXY=192.168.31.223,localhost,127.0.0.1
